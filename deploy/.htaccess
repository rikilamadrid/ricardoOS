# RicardoOS — Apache/LiteSpeed config for the static export on Hostinger.
# Upload this to public_html alongside the contents of `out/`.
# Version-controlled so it survives a re-extract; keep in sync with the build.

# Serve the static 404 page
ErrorDocument 404 /404.html

# OG/Twitter share images export as extensionless files named
# `opengraph-image` (Next metadata routes). Force image/png or crawlers
# reject them.
<FilesMatch "(opengraph|twitter)-image$">
  ForceType image/png
</FilesMatch>

# PWA manifest: not all hosts map .webmanifest by default. Serve the correct
# type so Chrome/Android accept "Add to Home Screen".
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>

# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect www → root (canonical = bare domain; flip if you prefer www)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Caching: long-cache hashed assets, always revalidate HTML
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|gif|svg|ico|mp3)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
